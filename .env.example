# ── PrepGenius AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in all required values before running.
# NEVER commit .env to version control.

# ── Django ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=prepgenius.ai,www.prepgenius.ai
CORS_ALLOWED_ORIGINS=https://prepgenius.ai,https://www.prepgenius.ai
# Local dev: config.settings.dev  |  Production: config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.prod

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
POSTGRES_DB=prepgenius
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://postgres:change-me-strong-password@db:5432/prepgenius

# ── Redis (broker + cache + rate-limit) ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=prepgenius.ai

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=/api/v1

# ── AI Providers (ai_gateway only — NEVER expose to client) ───────────────────
# Fallback chain: Groq → OpenAI → DeepSeek V4 (PRD v4 §7, SAD §3)
GROQ_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
AI_PROVIDER_ORDER=groq,openai,deepseek

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Messaging ─────────────────────────────────────────────────────────────────
# Telegram first — WhatsApp only after Telegram ships (PRD v4 §14)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── n8n (automation orchestration) ───────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change-me-strong-password
N8N_HOST=n8n.prepgenius.ai
N8N_WEBHOOK_URL=https://n8n.prepgenius.ai
# Local dev: http  |  Production: https
N8N_PROTOCOL=https

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@prepgenius.ai
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=PrepGenius AI <noreply@prepgenius.ai>

# ── Storage (local VPS first, R2 at scale gate — PRD v4 §11) ─────────────────
UPLOAD_DIR=/app/uploads
# Cloudflare R2 — enable only after reaching scale gate
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=
