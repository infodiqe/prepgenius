# ── PrepGenius AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in all required values before running.
# NEVER commit .env to version control.

# ── Django ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
# Append `django` (the Docker service name) so the `next` container's
# server-side fetches to http://django:8000 pass Django's Host header check.
ALLOWED_HOSTS=prepgenius.ai,www.prepgenius.ai,django
CORS_ALLOWED_ORIGINS=https://prepgenius.ai,https://www.prepgenius.ai
# Local dev: config.settings.dev  |  Production: config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.prod

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
POSTGRES_DB=prepgenius
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://postgres:change-me-strong-password@db:5432/prepgenius

# ── Backups (RC-03 P0-1 · PRD v4 §11 — off-box copy mandatory before go-live) ──
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7
# Off-box destination (e.g. an rclone remote "r2:prepgenius-backups"). Leave
# empty to keep backups LOCAL ONLY (not acceptable for production go-live).
BACKUP_REMOTE=

# Local development only: opt out of the production SECRET_KEY/DB-password guard.
# NEVER set this in a real production .env.
# ALLOW_INSECURE_SECRET_KEY=true

# ── Redis (broker + cache + rate-limit) ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=prepgenius.ai
# Used by init-letsencrypt.sh when requesting the certificate
LETSENCRYPT_EMAIL=admin@prepgenius.ai

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=/api/v1

# ── AI Providers & Credits (ai_gateway only — NEVER expose to client) ─────────
# Fallback chain: Groq → OpenAI → DeepSeek V4 (PRD v4 §7, SAD §3)
GROQ_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AI_PROVIDER_CHAIN=groq,openai,deepseek
AI_PROVIDER_ORDER=groq,openai,deepseek
# Optional per-provider base-URL overrides (JSON), e.g. {"openai":"https://proxy/v1"}
AI_PROVIDER_BASE_URLS={}

# Mapping of operations to models per provider (JSON format)
AI_MODELS={"tutor_chat":{"groq":"llama-3.3-70b-versatile","openai":"gpt-4o-mini","deepseek":"deepseek-chat","mock":"mock-model"},"explain_question":{"groq":"llama-3.3-70b-versatile","openai":"gpt-4o-mini","deepseek":"deepseek-chat","mock":"mock-model"}}
# Per-provider default model used when AI_MODELS has no entry for a prompt type (JSON)
AI_DEFAULT_MODELS={"groq":"llama-3.3-70b-versatile","openai":"gpt-4o-mini","anthropic":"claude-3-5-sonnet-latest","gemini":"gemini-1.5-flash","deepseek":"deepseek-chat","mock":"mock-model"}
# AI gateway retry / timeout policy
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_SECONDS=0.5
AI_REQUEST_TIMEOUT_SECONDS=30.0
# Token pricing per 1K tokens for cost monitoring (JSON), empty = cost 0
AI_TOKEN_PRICING={}
# Async batch generation bounds (per-request cap clamps the chunk size)
AI_MAX_BATCH_QUESTIONS=500
AI_GENERATION_BATCH_SIZE=20
# AI credit cost per operation as credits-per-unit, keyed by prompt type (JSON,
# strings → Decimal). Question generation charges per question; the gateway
# reserves→commits/releases via the credits module. 0/absent = free.
AI_CREDIT_COSTS={"question_generation":"1"}
# Provider circuit breaker (skip a repeatedly-failing provider, auto-recover)
AI_CIRCUIT_BREAKER_ENABLED=true
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_COOLDOWN_SECONDS=60.0

CREDIT_FREE_MONTHLY_GRANT=100
# Credit cost configuration: {operation: {reserve_estimate, token_to_credit}} (JSON format)
CREDIT_COSTS={"tutor_chat":{"reserve_estimate":10.0,"token_to_credit":0.05},"explain_question":{"reserve_estimate":5.0,"token_to_credit":0.05}}

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Messaging ─────────────────────────────────────────────────────────────────
# Telegram first — WhatsApp only after Telegram ships (PRD v4 §14)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── n8n (automation orchestration) ───────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change-me-strong-password
N8N_HOST=n8n.prepgenius.ai
N8N_WEBHOOK_URL=https://n8n.prepgenius.ai
# Local dev: http  |  Production: https
N8N_PROTOCOL=https

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@prepgenius.ai
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=PrepGenius AI <noreply@prepgenius.ai>

# ── Storage (local VPS first, R2 at scale gate — PRD v4 §11) ─────────────────
UPLOAD_DIR=/app/uploads
# Cloudflare R2 — enable only after reaching scale gate
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=
