      security:
      - cookieJWT: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ExamRead'
          description: ''
  /api/v1/exams/{exam_pk}/subjects/:
    get:
      operationId: v1_exams_subjects_list
      description: Retrieve all subjects belonging to an exam.
      summary: List subjects for exam
      parameters:
